# ─── Google Analytics 4 ───
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Google Search Console (verification meta tag content) ───
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-site-verification-code

# ─── HubSpot CRM ───
HUBSPOT_ACCESS_TOKEN=your-hubspot-private-app-token
HUBSPOT_PORTAL_ID=your-portal-id

# ─── Resend (transactional email) ───
RESEND_API_KEY=re_xxxxxxxxxxxx

# ─── Brevo / Sendinblue (newsletter) ───
BREVO_API_KEY=your-brevo-v3-api-key
BREVO_LIST_ID=1

# ─── Calendly ───
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/hrcghana/educational-psychology-course

# ─── Admin ───
ADMIN_SECRET=your-secure-random-string
