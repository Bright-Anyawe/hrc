# ─── Calendly Integration ───
# Create a free Calendly account at https://calendly.com
# Create an event type (e.g., "Consultation") and paste your scheduling link below.
# Example: https://calendly.com/your-username/consultation
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/hrcghana/educational-psychology-course

# ─── Email (Resend) ───
# Used by the contact form API route (app/api/contact/route.ts)
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# ─── HubSpot CRM ───
# Used to sync contact form & booking submissions to HubSpot CRM (free tier).
# 1. Go to https://app.hubspot.com > Settings > Integrations > Private Apps
# 2. Create a Private App with at least scopes: crm.objects.contacts.write, crm.objects.deals.write, crm.objects.contacts.read
# 3. Copy the access token and paste it here
HUBSPOT_ACCESS_TOKEN=

# ─── Admin Dashboard Access ───
# Used to protect the /admin/leads page. Choose a long random string.
# Access it at: /admin/leads?secret=YOUR_SECRET
ADMIN_SECRET=

# ─── Google Analytics (optional) ───
# Used for tracking booking events (service selected, booking completed)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
